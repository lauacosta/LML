---
import FormattedDate from "../components/FormattedDate.astro";
import TeamPresentation from "../components/TeamPresentation.astro";
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
const posts = (await getCollection("desafios")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
  title="LML Gestión"
  description="LML Gestión es un equipo de trabajo conformado por Lautaro Acosta, Lautaro Faccini, Felipe Fidanza, Tobias Stegmayer y Moselli Yamil; alumnos de la catedra de Gestión Gerencial. Este portfolio tiene como objetivo presentar las actividades realizadas en el cursado de la materia.">
  <main>
    <section class="hero-section">
      <div class="hero-wrapper">
        <h1>lml gestión</h1>
        <div class="hero-info">
          <p>Gestión Gerencial</p>
          <p>Portfolio - 2026</p>
        </div>
      </div>
    </section>

    <section>
      <div class="index-wrapper">
        <h2>Conocé al equipo</h2>
        <TeamPresentation
          nombre="Lautaro Acosta"
          linkedin="https://www.linkedin.com/in/tobias-stegmayer-612551218/"
          linkVideo="https://www.youtube.com/watch?v=DOizrHLVZ4Y"
        />
        <TeamPresentation
          nombre="Lautaro Faccini"
          linkedin="https://www.linkedin.com/in/tobias-stegmayer-612551218/"
          linkVideo="https://www.youtube.com/watch?v=DOizrHLVZ4Y"
        />
        <TeamPresentation
          nombre="Felipe Fidanza"
          linkedin="https://www.linkedin.com/in/tobias-stegmayer-612551218/"
          linkVideo="https://www.youtube.com/watch?v=DOizrHLVZ4Y"
        />
        <TeamPresentation
          nombre="Tobias Stegmayer"
          linkedin="https://www.linkedin.com/in/tobias-stegmayer-612551218/"
          linkVideo="https://www.youtube.com/watch?v=DOizrHLVZ4Y"
        />
        <TeamPresentation
          nombre="Yamil Moselli"
          linkedin="https://www.linkedin.com/in/tobias-stegmayer-612551218/"
          linkVideo="https://www.youtube.com/watch?v=DOizrHLVZ4Y"
        />
      </div>
    </section>

    <section>
      <div class="index-wrapper">
        <h2 id="desafios">Desafíos</h2>
        <div class="desafios-grid">
          {
            posts.map((post) => (
              <a href={`/desafios/${post.id}/`} class="desafio-card">
                <article>
                  <div class="card-image-wrapper">
                    {post.data.heroImage && (
                      <Image
                        src={post.data.heroImage}
                        alt={post.data.title}
                        width={720}
                        height={400}
                        loading="lazy"
                      />
                    )}
                  </div>
                  <div class="card-content">
                    <p class="card-date">
                      <FormattedDate date={post.data.pubDate} />
                    </p>
                    <h3>{post.data.title}</h3>
                    <span class="view-more">Leer desafío →</span>
                  </div>
                </article>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .section {
    width: 100%;
    display: flex;
    flex-direction: column;

    align-items: center;
  }

  .hero-section {
    height: 100dvh;
    width: 100%;
    background-color: #070707;
    /* background-image: url("../assets/lospibe.png"); */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: end;
    align-items: center;
  }

  .hero-wrapper {
    --max-width: 754px;
    --padding: 1rem;

    width: min(var(--max-width), 100% - (var(--padding) * 4));
    margin-inline: auto;
    margin-block: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: end;
    align-items: center;
    gap: 2rem;
    h1 {
      color: #fff;
      font-size: 10rem;
      margin: 0;
    }

    div {
      display: flex;
      justify-content: space-between;
      width: 100%;
      gap: 1rem;

      p {
        color: var(--text-200);
        margin: 0;
      }
    }
  }
</style>
