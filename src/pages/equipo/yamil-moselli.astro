---
import Layout from "../../layouts/Layout.astro";
import { getYouTubeEmbedUrl } from "../../utils/youtube";

const nombre = "Yamil Moselli";
const linkVideo = "https://youtu.be/JTrhzwZe0zY?si=W1yUG5ZKdgby-FTr";

const embedUrl = getYouTubeEmbedUrl(linkVideo);
---

<Layout
  title=`Perfil de ${nombre}`
  description="Yamil Moselli, estudiante del último año de  ingenieria en sistemas.">
  <main>
    <section>
      <div class="video-container">
        <iframe
          id={`video-${nombre.replace(/\s+/g, "")}`}
          src={embedUrl}
          title={`Video de ${nombre}`}
          frameborder="0"
          loading="lazy"
          fetchpriority="low"
          allow="autoplay; encrypted-media"
          allowfullscreen></iframe>
      </div>
      <div class="blog-wrapper">
        <h1>{nombre}</h1>
        <p>
          Estudiante de Ingeniería en Sistemas de Información, amante del fútbol y el cine. Dentro de un equipo me gusta tomar el rol de líder para coordinar las actividades de cada integrante del 
          equipo y tener una visión general de su trabajo. Actualmente me gusta programar en Java y estoy interesado en adentrarme en el la rama de los datos.
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .video-container {
    aspect-ratio: 16 / 9;
    border-radius: 1rem;
    overflow: hidden;
    background: #000;

    margin-top: 9rem;

    --max-width: 1020px;
    --padding: 1rem;

    width: min(var(--max-width), 100% - (var(--padding) * 2));
    margin-inline: auto;
  }

  iframe {
    width: 100%;
    height: 100%;
  }
</style>
