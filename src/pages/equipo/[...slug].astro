---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPersonal from "../../layouts/BlogPersonal.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blogsPersonales");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"blogsPersonales">;

const post = Astro.props;
const { Content } = await render(post);
---

<BlogPersonal {...post.data}>
  <Content />
</BlogPersonal>
