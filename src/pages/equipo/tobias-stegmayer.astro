---
import Layout from "../../layouts/Layout.astro";
import { getYouTubeEmbedUrl } from "../../utils/youtube";

const nombre = "Tobias Stegmayer";
const linkVideo = "https://youtu.be/YNX4HITzZuI?si=XDgNzhoGAff0KlYY";

const embedUrl = getYouTubeEmbedUrl(linkVideo);
---

<Layout
  title=`Perfil de ${nombre}`
  description="Tobias Stegmayer, actualmente (2025) estudiante del último año de  ingenieria en sistemas, programador y artista.">
  <main>
    <section>
      <div class="video-container">
        <iframe
          id={`video-${nombre.replace(/\s+/g, "")}`}
          src={embedUrl}
          title={`Video de ${nombre}`}
          frameborder="0"
          loading="lazy"
          fetchpriority="low"
          allow="autoplay; encrypted-media"
          allowfullscreen></iframe>
      </div>
      <div class="blog-wrapper">
        <h1>{nombre}</h1>
        <p>
          Casi ingeniero, amante del mate, la programación y la resolución de
          problemas. Siempre busco aprender de mis errores (así como de mis
          victorias) y mejorar constantemente. Mis objetivos son entrar al
          mercado laboral, aumentar mi networking y crear una startup o empresa
          de base tecnológica.
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .video-container {
    aspect-ratio: 16 / 9;
    border-radius: 1rem;
    overflow: hidden;
    background: #000;

    margin-top: 9rem;

    --max-width: 1020px;
    --padding: 1rem;

    width: min(var(--max-width), 100% - (var(--padding) * 2));
    margin-inline: auto;
  }

  iframe {
    width: 100%;
    height: 100%;
  }
</style>
