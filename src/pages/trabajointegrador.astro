---
import BlogTpi from "../layouts/BlogTpi.astro";
import { getEntry, render } from "astro:content";

const post = await getEntry("tpi", "trabajointegrador");
if (!post) throw new Error("No se encontró el trabajo integrador");
const { Content, headings } = await render(post);
---

<BlogTpi {...post.data} backHref="/" headings={headings}>
  <Content />
</BlogTpi>
