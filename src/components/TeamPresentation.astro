---
const { nombre, linkedin, linkVideo } = Astro.props;

const transformName = (nombre: string) => {
  return nombre.toLowerCase().replace(/\s+/g, "-");
};

const getYouTubeEmbedUrl = (url: string) => {
  const regExp =
    /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
  const match = url.match(regExp);
  const videoId = match && match[2].length === 11 ? match[2] : null;
  return videoId
    ? `https://www.youtube.com/embed/${videoId}?enablejsapi=1`
    : null;
};

const embedUrl = getYouTubeEmbedUrl(linkVideo);
---

<article>
  <div class="autoShow">
    <h3>{nombre}</h3>

    <a href={linkedin}>
      <svg
        height="800px"
        width="800px"
        version="1.1"
        id="Layer_1"
        xmlns="http://www.w3.org/2000/svg"
        xmlns:xlink="http://www.w3.org/1999/xlink"
        viewBox="0 0 382 382"
        xml:space="preserve">
        <path
          style="fill:#0077B7;"
          d="M347.445,0H34.555C15.471,0,0,15.471,0,34.555v312.889C0,366.529,15.471,382,34.555,382h312.889
	C366.529,382,382,366.529,382,347.444V34.555C382,15.471,366.529,0,347.445,0z M118.207,329.844c0,5.554-4.502,10.056-10.056,10.056
	H65.345c-5.554,0-10.056-4.502-10.056-10.056V150.403c0-5.554,4.502-10.056,10.056-10.056h42.806
	c5.554,0,10.056,4.502,10.056,10.056V329.844z M86.748,123.432c-22.459,0-40.666-18.207-40.666-40.666S64.289,42.1,86.748,42.1
	s40.666,18.207,40.666,40.666S109.208,123.432,86.748,123.432z M341.91,330.654c0,5.106-4.14,9.246-9.246,9.246H286.73
	c-5.106,0-9.246-4.14-9.246-9.246v-84.168c0-12.556,3.683-55.021-32.813-55.021c-28.309,0-34.051,29.066-35.204,42.11v97.079
	c0,5.106-4.139,9.246-9.246,9.246h-44.426c-5.106,0-9.246-4.14-9.246-9.246V149.593c0-5.106,4.14-9.246,9.246-9.246h44.426
	c5.106,0,9.246,4.14,9.246,9.246v15.655c10.497-15.753,26.097-27.912,59.312-27.912c73.552,0,73.131,68.716,73.131,106.472
	L341.91,330.654L341.91,330.654z"
        ></path>
      </svg><p>linkedin.com/{transformName(nombre)}</p></a
    >
  </div>

  <div class="video-container">
    {
      embedUrl ? (
        <iframe
          id={`video-${nombre.replace(/\s+/g, "")}`}
          src={embedUrl}
          title={`Video de ${nombre}`}
          frameborder="0"
          loading="lazy"
          allow="autoplay; encrypted-media"
          allowfullscreen
        />
      ) : (
        <p>Video no disponible</p>
      )
    }
  </div>
</article>

<style>
  article {
    position: sticky;
    top: 6rem;
    display: flex;

    gap: 4rem;

    padding-block: 4rem;

    div {
      display: grid;
      align-items: center;
      margin-block: auto;
    }
  }

  .video-container {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 1rem;
    overflow: hidden;
    background: #000;
  }

  iframe {
    width: 100%;
    height: 100%;
  }
  h3 {
    font-size: 5rem;
    width: 404px;
  }
  svg {
    width: 24px;
    height: 24px;
  }

  a {
    color: #000;
    text-decoration: none;
    display: flex;
    gap: 0.5rem;
    align-items: center;

    p {
      margin: 0;
      font-weight: 500;
      color: #4d4d4d;
    }
  }

  .autoShow {
    animation: text-appear both;
    animation-timeline: view(50% 20%);
    animation-range: entry 20% cover 120vh;
  }

  @keyframes text-appear {
    0% {
      opacity: 0;
      transform: translateY(100px);
    }
    50% {
      opacity: 1;
      transform: translateY(0);
    }

    100% {
      opacity: 0;
      transform: translateY(100px);
    }
  }

  @media (max-width: 900px) {
    article {
      display: flex;
      flex-direction: column;
      position: static;
      gap: 2rem;
    }
    h3 {
      width: 100%;
      font-size: 3rem;
    }

    .autoShow {
      animation: none;
    }
  }
</style>
