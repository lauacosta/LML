---
import HeaderLink from "./HeaderLink.astro";
import { Image } from "astro:assets";
import imgLautaroA from "../assets/equipo/lauti-a.webp";
import imgLautaroF from "../assets/equipo/lauti-f.webp";
import imgFelipe from "../assets/equipo/felipe.webp";
import imgYamil from "../assets/equipo/yamil.webp";
import imgTobias from "../assets/equipo/tobias.webp";

const { isNotHome } = Astro.props;
---

<header class:list={["header", { "not-home": isNotHome }]}>
  <nav>
    <a href="/" transition:persist class="logo-link">
      <svg
        width="90"
        height="57"
        viewBox="0 0 90 57"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="logo">
        <path
          class="logo-path"
          d="M2 54.8619C8.5 50.3619 21 40.8608 25.5 35.3608C31.2079 28.3845 34 21.8619 36 16.8619C38 11.8619 39.5463 5.14664 36.5 2.86187C32.5 -0.13822 26.3869 4.65431 24.5 17.8619C22.5 31.861 31.5 43.3619 42 44.3619C52.5 45.3619 64 36.3618 72 17.8619C80 -0.638074 69.616 -1.13836 65 7.36164C62.6139 11.7555 43 48.8614 88 54.8619"
          stroke="white"
          stroke-width="4"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>

    <div class="internal-links">
      <HeaderLink href="/">Inicio</HeaderLink>
      <div class="dropdown">
        <HeaderLink href="" class="dropdown-trigger"> Equipo </HeaderLink>

        <div class="dropdown-content">
          <div class="dropdown-grid">
            <a href="/equipo/lautaro-acosta">
              <div class="team-item">
                <Image
                  src={imgLautaroA}
                  alt="Lautaro Acosta Quintana"
                  width={90}
                  height={90}
                />
                <span>Lautaro <br />Acosta Quintana</span>
              </div>
            </a>

            <a href="/equipo/lautaro-faccini">
              <div class="team-item">
                <Image
                  src={imgLautaroF}
                  alt="Lautaro Faccini"
                  width={90}
                  height={90}
                />
                <span>Lautaro <br />Faccini</span>
              </div>
            </a>

            <a href="/equipo/felipe-fidanza">
              <div class="team-item">
                <Image
                  src={imgFelipe}
                  alt="Felipe Fidanza"
                  width={90}
                  height={90}
                />
                <span>Felipe <br />Fidanza</span>
              </div>
            </a>

            <a href="/equipo/tobias-stegmayer">
              <div class="team-item">
                <Image
                  src={imgTobias}
                  alt="Tobías Stegmayer"
                  width={90}
                  height={90}
                />
                <span>Tobías <br />Stegmayer</span>
              </div>
            </a>

            <a href="/equipo/yamil-moselli">
              <div class="team-item">
                <Image
                  src={imgYamil}
                  alt="Yamil Moselli"
                  width={90}
                  height={90}
                />
                <span>Yamil <br />Moselli</span>
              </div>
            </a>
          </div>
        </div>
      </div>
      <HeaderLink href="/desafios">Desafios</HeaderLink>
      <HeaderLink href="/trabajointegrador">Integrador</HeaderLink>
    </div>
  </nav>
</header>

<script>
  const initLogoAnimation = () => {
    const logoLink = document.querySelector(".logo-link");
    const path = document.querySelector(".logo-path") as SVGPathElement;

    if (path && logoLink) {
      const length = path.getTotalLength();

      path.style.strokeDasharray = `${length} ${length}`;
      path.style.strokeDashoffset = "0";

      logoLink.addEventListener("mouseenter", () => {
        path.style.transition = "none";
        path.style.strokeDashoffset = `${length}`;

        path.getBoundingClientRect();

        path.style.transition = "stroke-dashoffset 0.8s ease-in-out";
        path.style.strokeDashoffset = "0";
      });
    }
  };

  document.addEventListener("astro:page-load", initLogoAnimation);
</script>
<style>
  header {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 10;
    width: 100%;
    margin: 0;
    color: #fff;
  }

  .logo {
    height: 40px;
    width: fit-content;
    .logo-path {
      stroke: #fff;
    }
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    --max-width: 1400px;
    --padding: 1rem;

    width: min(var(--max-width), 100% - (var(--padding) * 2));
    margin-inline: auto;
  }
  nav a,
  nav span {
    color: var(--text-200);
    text-decoration: none;
    padding-block: 1.5rem;
    display: grid;
    align-content: center;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
    color: #fff;
  }

  .internal-links {
    display: flex;
    gap: 2.5rem;

    font-size: 1rem;
  }

  .not-home {
    background-color: #fff;
    .internal-links a,
    .internal-links span {
      color: rgb(var(--gray));
    }

    .internal-links a.active {
      color: #000;
    }
    .logo-path {
      stroke: #000;
    }
  }

  @media (max-width: 900px) {
    .logo {
      height: 28px;
    }

    .internal-links {
      font-size: 0.9rem;
      gap: 1.5rem;
    }
  }

  .dropdown-content::before {
    content: "";
    position: absolute;
    top: -20px;
    left: 0;
    width: 100%;
    height: 25px;
    background: transparent;
  }

  .dropdown {
    height: 100%;
    display: flex;
    align-items: center;
  }

  .dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }

  .dropdown-content {
    opacity: 0;
    visibility: hidden;

    position: absolute;

    top: 100%;
    left: 0;
    right: 0;

    width: auto;

    margin-inline: 1rem;

    background: #0c0908;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
    border-radius: 16px;
    padding: 2rem;
    z-index: 100;

    transform: translateY(10px);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0.3s;
  }

  .dropdown:hover .dropdown-content {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .dropdown-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
    max-width: 1400px;
    margin: 0 auto;

    a {
      padding-block: 0 !important;
    }
  }

  .team-item {
    display: flex;
    align-items: center;

    gap: 1rem;
    padding: 1rem !important;
    border-radius: 8px;
    transition: backgroundColor 0.2s;
    text-decoration: none !important;
  }

  .team-item span {
    color: var(--text-200);

    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .team-item:hover span {
    color: #fff;
  }
  .team-item:hover {
    background-color: #131214;
  }

  .team-item img {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    object-fit: cover;
    background-color: #eee;
  }

  .not-home .dropdown-content {
    border-top: 1px solid #ddd;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .dropdown-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
