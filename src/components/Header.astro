---
import HeaderLink from "./HeaderLink.astro";

const { isNotHome } = Astro.props;
---

<header class:list={["header", { "not-home": isNotHome }]}>
  <nav>
    <a href="/" transition:persist class="logo-link">
      <svg
        width="90"
        height="57"
        viewBox="0 0 90 57"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="logo">
        <path
          class="logo-path"
          d="M2 54.8619C8.5 50.3619 21 40.8608 25.5 35.3608C31.2079 28.3845 34 21.8619 36 16.8619C38 11.8619 39.5463 5.14664 36.5 2.86187C32.5 -0.13822 26.3869 4.65431 24.5 17.8619C22.5 31.861 31.5 43.3619 42 44.3619C52.5 45.3619 64 36.3618 72 17.8619C80 -0.638074 69.616 -1.13836 65 7.36164C62.6139 11.7555 43 48.8614 88 54.8619"
          stroke="white"
          stroke-width="4"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>

    <div class="internal-links">
      <HeaderLink href="/">Inicio</HeaderLink>
      <HeaderLink href="/desafios">Desafios</HeaderLink>
      <HeaderLink href="/trabajointegrador">Trabajo Práctico</HeaderLink>
    </div>
  </nav>
</header>

<script>
  // Función para inicializar la animación
  const initLogoAnimation = () => {
    const logoLink = document.querySelector(".logo-link");
    const path = document.querySelector(".logo-path") as SVGPathElement;

    if (path && logoLink) {
      const length = path.getTotalLength();

      // Estado inicial: oculto
      path.style.strokeDasharray = `${length} ${length}`;
      path.style.strokeDashoffset = "0"; // Empezamos visible o podrías empezar en 'length'

      logoLink.addEventListener("mouseenter", () => {
        // Reiniciar animación al entrar
        path.style.transition = "none";
        path.style.strokeDashoffset = `${length}`;

        // El "hack" para forzar el redibujado antes de la transición
        path.getBoundingClientRect();

        path.style.transition = "stroke-dashoffset 0.8s ease-in-out";
        path.style.strokeDashoffset = "0";
      });
    }
  };

  // Importante: Ejecutar en carga inicial y en cada transición de página de Astro
  document.addEventListener("astro:page-load", initLogoAnimation);
</script>
<style>
  header {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 10;
    width: 100%;
    margin: 0;
    color: #fff;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
  }

  .logo {
    height: 40px;
    width: fit-content;
    .logo-path {
      stroke: #fff;
    }
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    --max-width: 1400px;
    --padding: 1rem;

    width: min(var(--max-width), 100% - (var(--padding) * 2));
    margin-inline: auto;
    padding-block: 1.5rem;
  }
  nav a {
    color: var(--text-200);
    text-decoration: none;

    display: grid;
    align-content: center;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
    color: #fff;
  }

  .internal-links {
    display: flex;
    gap: 2.5rem;

    font-size: 1rem;
  }

  .not-home {
    background-color: #fff;
    .internal-links a {
      color: rgb(var(--gray));
    }

    .internal-links a.active {
      color: #000;
    }
    .logo-path {
      stroke: #000;
    }
  }
</style>
